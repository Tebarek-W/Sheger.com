# Copy to .env for local development
# Use STAGING credentials while building features; production keys only for prod EAS builds
# See docs/DEPLOYMENT.md and supabase/STAGING.md

# --- Staging (recommended for daily dev) ---
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_STAGING_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_STAGING_KEY

# --- Production (use only when testing prod locally) ---
# EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PRODUCTION_REF.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_PRODUCTION_KEY

# Aliases also supported:
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
