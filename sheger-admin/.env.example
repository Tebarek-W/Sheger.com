# Copy to .env.local for local development
# Use STAGING credentials while building features
# See docs/DEPLOYMENT.md and supabase/STAGING.md

# --- Staging (recommended for daily dev) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_STAGING_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_STAGING_KEY
SUPABASE_SECRET_KEY=sb_secret_YOUR_STAGING_SECRET

# --- Production (use only when testing prod locally) ---
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PRODUCTION_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_PRODUCTION_KEY
# SUPABASE_SECRET_KEY=sb_secret_YOUR_PRODUCTION_SECRET

# Aliases also supported:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
