# Used by Supabase CLI and GitHub Actions — do not commit real values
# Copy to supabase/.env.local for local CLI overrides (gitignored)

# SUPABASE_PROJECT_REF=your-staging-or-production-ref
# SUPABASE_ACCESS_TOKEN=your-personal-access-token

# Edge Function secrets (set via: supabase secrets set CHAPA_SECRET_KEY=CHASECK_TEST-...)
# CHAPA_SECRET_KEY=CHASECK_TEST-your-test-secret-key
# CHAPA_WEBHOOK_SECRET=your-webhook-secret-hash-from-chapa-dashboard
# CHAPA_MODE=test
